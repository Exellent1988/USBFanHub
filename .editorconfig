# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Python files
[*.py]
indent_size = 4
max_line_length = 120

# C/C++ files
[*.{c,h,cpp,hpp}]
indent_size = 4
max_line_length = 100

# CMake files
[{CMakeLists.txt,*.cmake}]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Makefiles (must use tabs)
[Makefile]
indent_style = tab

# KiCad files
[*.{kicad_sch,kicad_pcb,kicad_pro}]
indent_size = 2
insert_final_newline = false

# Git files
[.git*]
indent_size = 2
